rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function elevationValid() {
      return signedIn()
        && request.auth.token.elevatedUntil is int
        && request.auth.token.elevatedUntil > request.time.toMillis();
    }

    function isAdmin() {
      return elevationValid() && request.auth.token.admin == true;
    }

    function isAccount() {
      return signedIn() && request.auth.token.account == true;
    }

    function isElevatedStaff() {
      return elevationValid()
        && (request.auth.token.admin == true || request.auth.token.legacyRole == 'chongmu');
    }

    function isAppUser() {
      return isAccount() || isElevatedStaff();
    }

    function hasPermission(permission) {
      return isAdmin()
        || (isAppUser()
          && request.auth.token.permissions is list
          && request.auth.token.permissions.hasAny([permission]));
    }

    function ownsCreatedDoc(data) {
      return signedIn()
        && (data.createdById == request.auth.uid
          || (elevationValid()
            && request.auth.token.legacyRole == 'chongmu'
            && data.createdById == 'chongmu'));
    }

    function ownMember(memberId) {
      return isAccount() && request.auth.token.memberId == memberId;
    }

    match /songs/{songId} {
      allow read: if isAppUser();
      allow create: if hasPermission('song.manage');
      allow update: if isAdmin()
        || hasPermission('song.editAny')
        || (hasPermission('song.manage') && ownsCreatedDoc(resource.data));
      allow delete: if isAdmin()
        || (hasPermission('song.manage') && ownsCreatedDoc(resource.data));
    }

    match /songIndex/{shardId} {
      allow read: if isAppUser();
      allow write: if false;
    }

    match /schedules/{scheduleId} {
      allow read: if true;
      allow create: if hasPermission('schedule.manage');
      allow update: if isAdmin()
        || hasPermission('schedule.editAny')
        || (hasPermission('schedule.manage') && ownsCreatedDoc(resource.data));
      allow delete: if isAdmin()
        || (hasPermission('schedule.manage') && ownsCreatedDoc(resource.data));
    }

    match /settings/notice {
      allow read: if true;
      allow write: if hasPermission('notice.manage');
    }

    match /settings/publishedSeatingPlan {
      allow read: if true;
      allow write: if hasPermission('seating.manage');
    }

    match /settings/seatingPlans {
      allow read, write: if hasPermission('seating.manage');
    }

    match /settings/scores {
      allow read: if isAppUser();
      allow write: if false;
    }

    match /settings/admin {
      allow read, write: if false;
    }

    match /settings/{otherSetting} {
      allow read, write: if isAdmin() && otherSetting != 'admin';
    }

    match /members/{memberId} {
      allow read: if ownMember(memberId)
        || isAdmin()
        || hasPermission('member.view')
        || hasPermission('member.history')
        || hasPermission('member.manage')
        || hasPermission('member.delete')
        || hasPermission('attendance.view')
        || hasPermission('attendance.check')
        || hasPermission('attendance.delete')
        || hasPermission('account.manage')
        || hasPermission('song.manage')
        || hasPermission('seating.manage');
      allow create: if isAdmin() || hasPermission('member.manage');
      allow update: if isAdmin()
        || hasPermission('member.manage')
        || (ownMember(memberId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'photo', 'photoUpdatedAt', 'photoUpdatedByAccountId', 'photoUpdatedBy'
          ])
          && request.resource.data.photoUpdatedByAccountId == request.auth.uid);
      allow delete: if isAdmin() || hasPermission('member.delete');
    }

    match /accounts/{accountId} {
      allow read: if isAdmin()
        || hasPermission('account.manage')
        || hasPermission('account.pin')
        || (isAccount() && request.auth.uid == accountId);
      allow update: if isAccount()
        && request.auth.uid == accountId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['favorites']);
      allow create, delete: if false;
    }

    match /pushSubscriptions/{subscriptionId} {
      function validSubscription(data) {
        return data.keys().hasOnly([
            'uid', 'accountName', 'topics', 'subscription', 'userAgent', 'updatedAt'
          ])
          && data.uid == request.auth.uid
          && data.accountName is string
          && data.accountName.size() <= 60
          && data.userAgent is string
          && data.userAgent.size() <= 500
          && data.updatedAt is string
          && data.updatedAt.size() <= 40
          && data.topics is map
          && data.topics.keys().hasOnly(['scores', 'schedules'])
          && data.topics.scores is bool
          && data.topics.schedules is bool
          && data.subscription is map
          && data.subscription.keys().hasOnly(['endpoint', 'keys'])
          && data.subscription.endpoint is string
          && data.subscription.endpoint.size() <= 4096
          && data.subscription.keys is map
          && data.subscription.keys.keys().hasOnly(['auth', 'p256dh'])
          && data.subscription.keys.auth is string
          && data.subscription.keys.auth.size() <= 512
          && data.subscription.keys.p256dh is string
          && data.subscription.keys.p256dh.size() <= 512;
      }

      allow get: if isAccount() && resource.data.uid == request.auth.uid;
      allow list: if false;
      allow create: if isAccount() && validSubscription(request.resource.data);
      allow update: if isAccount()
        && resource.data.uid == request.auth.uid
        && validSubscription(request.resource.data);
      allow delete: if isAccount() && resource.data.uid == request.auth.uid;
    }

    match /attendance/{attendanceId} {
      allow read: if isAdmin()
        || hasPermission('attendance.view')
        || hasPermission('attendance.check')
        || hasPermission('attendance.delete');
      allow create, update: if isAdmin() || hasPermission('attendance.check');
      allow delete: if isAdmin() || hasPermission('attendance.delete');
    }

    match /activityLogs/{logId} {
      allow create: if isAppUser();
      allow read, update, delete: if isAdmin();
    }

    match /mediaArchive/{archiveId} {
      allow read: if isAppUser();
      allow create: if isAdmin()
        || (hasPermission('archive.upload')
          && request.resource.data.uploadedById == request.auth.uid
          && request.resource.data.keys().hasOnly([
            'title', 'description', 'date', 'part', 'type', 'url', 'path',
            'fileSize', 'uploadedAt', 'uploadedById', 'albumId', 'albumTitle',
            'reactions', 'reactionUpdatedAt', 'updatedAt', 'updatedBy'
          ]));
      allow update: if isAdmin()
        || (hasPermission('archive.manageMine')
          && resource.data.uploadedById == request.auth.uid
          && request.resource.data.uploadedById == resource.data.uploadedById
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'title', 'description', 'date', 'part', 'albumId', 'albumTitle',
            'updatedAt', 'updatedBy'
          ]))
        || (hasPermission('archive.organize')
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'albumId', 'albumTitle', 'updatedAt', 'updatedBy'
          ]));
      allow delete: if isAdmin()
        || (hasPermission('archive.manageMine')
          && resource.data.uploadedById == request.auth.uid);
    }

    match /mediaArchivePrivate/{archiveId} {
      allow get, list: if isAdmin()
        || (isAccount() && resource.data.ownerId == request.auth.uid);
      allow create: if isAdmin()
        || (hasPermission('archive.upload')
          && request.resource.data.ownerId == request.auth.uid);
      allow update: if isAdmin()
        || (hasPermission('archive.manageMine')
          && resource.data.ownerId == request.auth.uid
          && request.resource.data.ownerId == resource.data.ownerId);
      allow delete: if isAdmin()
        || (hasPermission('archive.manageMine')
          && resource.data.ownerId == request.auth.uid);
    }

    match /archiveReactions/{reactionId} {
      function validOwnReaction(data) {
        return isAccount()
          && data.keys().hasOnly([
            'archiveId', 'uid', 'type', 'name', 'part', 'label', 'updatedAt'
          ])
          && data.uid == request.auth.uid
          && reactionId == data.archiveId + '_' + request.auth.uid
          && data.archiveId is string
          && data.archiveId.size() <= 180
          && data.type in [
            'heart', 'grace', 'cheer', 'thanks', 'celebrate', 'surprise',
            'awkward', 'tricky'
          ]
          && data.name is string
          && data.name.size() <= 60
          && data.part is string
          && data.part.size() <= 30
          && data.label is string
          && data.label.size() <= 120
          && data.updatedAt is string
          && data.updatedAt.size() <= 40;
      }

      allow get, list: if isAdmin()
        || (isAccount() && resource.data.uid == request.auth.uid);
      allow create: if validOwnReaction(request.resource.data);
      allow update: if resource.data.uid == request.auth.uid
        && request.resource.data.archiveId == resource.data.archiveId
        && validOwnReaction(request.resource.data);
      allow delete: if isAccount() && resource.data.uid == request.auth.uid;
    }

    match /archiveAlbums/{albumId} {
      allow read: if isAppUser();
      allow create, update, delete: if isAdmin() || hasPermission('archive.organize');
    }

    match /archiveComments/{commentId} {
      allow read, write: if false;
    }

    match /scores/{scoreId} {
      allow read: if isAppUser();
      allow write: if false;
    }

    match /issueReports/{reportId} {
      function validIssueReport(data) {
        return isAccount()
          && data.keys().hasOnly([
            'uid', 'accountName', 'part', 'message', 'tab', 'appVersion',
            'buildSha', 'userAgent', 'viewport', 'createdAt', 'status'
          ])
          && data.uid == request.auth.uid
          && data.accountName is string
          && data.accountName.size() <= 60
          && data.part is string
          && data.part.size() <= 40
          && data.message is string
          && data.message.size() >= 5
          && data.message.size() <= 1200
          && data.tab is string
          && data.tab.size() <= 40
          && data.appVersion is string
          && data.appVersion.size() <= 40
          && data.buildSha is string
          && data.buildSha.size() <= 80
          && data.userAgent is string
          && data.userAgent.size() <= 500
          && data.viewport is string
          && data.viewport.size() <= 40
          && data.createdAt is string
          && data.createdAt.size() <= 40
          && data.status == 'open';
      }

      allow create: if validIssueReport(request.resource.data);
      allow read: if isAdmin();
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status', 'resolvedAt', 'resolvedBy', 'updatedAt'
        ]);
      allow delete: if isAdmin();
    }

    match /authSecrets/{secretId} {
      allow read, write: if false;
    }

    match /securityRateLimits/{limitId} {
      allow read, write: if false;
    }

    match /pushDeliveryEvents/{eventId} {
      allow read, write: if false;
    }
  }
}
