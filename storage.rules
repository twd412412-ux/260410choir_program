rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function elevationValid() {
      return signedIn()
        && request.auth.token.elevatedUntil > request.time.toMillis();
    }

    function isAdmin() {
      return elevationValid() && request.auth.token.admin == true;
    }

    function isAppUser() {
      return signedIn()
        && (request.auth.token.account == true
          || (elevationValid()
            && (request.auth.token.admin == true || request.auth.token.legacyRole == 'chongmu')));
    }

    function hasPermission(permission) {
      return isAdmin()
        || (isAppUser()
          && request.auth.token.permissions is list
          && request.auth.token.permissions.hasAny([permission]));
    }

    function validImage() {
      return request.resource.contentType.matches('image/.*')
        && request.resource.size < 5 * 1024 * 1024;
    }

    match /profiles/{ownerId}/{imageId} {
      allow read: if isAppUser();
      allow create, update: if validImage()
        && (isAdmin()
          || hasPermission('member.manage')
          || (request.auth.token.account == true && request.auth.uid == ownerId));
      allow delete: if isAdmin()
        || hasPermission('member.manage')
        || (request.auth.token.account == true && request.auth.uid == ownerId);
    }

    match /profiles/{legacyImageId} {
      allow read: if isAppUser();
      allow create, update, delete: if isAdmin() || hasPermission('member.manage');
    }

    match /archive/{ownerId}/{part}/{fileName} {
      allow read: if isAppUser();
      allow create, update: if validImage()
        && (isAdmin() || (hasPermission('archive.upload') && request.auth.uid == ownerId));
      allow delete: if isAdmin()
        || (hasPermission('archive.manageMine') && request.auth.uid == ownerId);
    }

    match /archive/{legacyPart}/{legacyFile} {
      allow read: if isAppUser();
      allow create, update: if validImage() && (isAdmin() || hasPermission('archive.upload'));
      allow delete: if isAdmin();
    }

    match /scores/{scoreId}/{filePath=**} {
      allow read: if false;
      allow create: if hasPermission('score.manage')
        && request.resource.contentType == 'application/pdf'
        && request.resource.size < 30 * 1024 * 1024;
      allow update, delete: if false;
    }
  }
}
